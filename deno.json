{
  "tasks": {
    "viewer": "deno run --allow-net --allow-read --allow-env src/server.ts",
    "dev": "deno run --watch --allow-net --allow-read --allow-env src/server.ts",
    "fmt": "deno fmt src/ web/",
    "check": "deno check src/*.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  }
}
